# This file is used to set environment variables for the application.

# KuroBBS configuration
KUROBBS_ENABLED=true
KUROBBS_TOKEN=your_kurobbs_token_here
KUROBBS_ROLE_ID=your_kurobbs_role_id_here
KUROBBS_USER_ID=your_kurobbs_user_id_here
KUROBBS_IP_ADDR=your_kurobbs_ip_address_here

# Tajiduo configuration
TAJIDUO_ENABLED=true
TAJIDUO_REFRESH_TOKEN=your_tajiduo_refresh_token_here
TAJIDUO_UID=your_tajiduo_uid_here
TAJIDUO_DEVICE_ID=your_tajiduo_device_id_here
TAJIDUO_GAME_ID=your_tajiduo_game_id_here
